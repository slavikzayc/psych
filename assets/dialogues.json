      "authority_scale": 2,
      "medication_scale": 0,
      "fail_sanity_damage": 3,
      "nextnode_id": 2032
    },
    {
      "id": 15,
      "node_id": 2032,
      "text": "Я слышу вас. И всё равно останусь рядом.",
      "base_impact": 8,
